<Page
    x:Class="FluentCleaner.Views.CleanerPage"
    NavigationCacheMode="Required"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FluentCleaner.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

    <!-- Two rows: fixed top bar + everything else -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- TOP BAR - mirrors the two-panel layout below so the divider lines up.
             Left half=search box. Right half=results header OR detail header. -->
        <Border Grid.Row="0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200" MaxWidth="420" /> <!-- matches left panel -->
                    <ColumnDefinition Width="1" />                                 <!-- divider pixel -->
                    <ColumnDefinition Width="*" />                                 <!-- matches right panel -->
                </Grid.ColumnDefinitions>

                <!-- Search box;I wired here textChanged in code-behind to avoid binding lag -->
                <AutoSuggestBox Grid.Column="0"
                                FontSize="13"
                                Margin="8,5"
                                VerticalAlignment="Center"
                                PlaceholderText="Search"
                                QueryIcon="Find"
                                Text="{x:Bind ViewModel.SearchText, Mode=OneWay}"
                                TextChanged="SearchBox_TextChanged" />

                <Border Grid.Column="1"
                        Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                <Grid Grid.Column="2" Padding="12,5">

                    <!-- Results header; its visible while the list is showing (not in detail view) -->
                    <Grid Visibility="{x:Bind ViewModel.IsShowingList, Mode=OneWay,
                              Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />  <!-- total size badge -->
                            <ColumnDefinition Width="Auto" />  <!-- [...] actions menu -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Analysis results"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />

                        <!-- Sum of all scanned entries; empty until Analyze finishes -->
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.TotalSize, Mode=OneWay}"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                   Style="{StaticResource SubtitleTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />

                        <!-- Global [...] actions: select/sort/expand -->
                        <Button Grid.Column="2"
                                Width="28" Height="28" Padding="0"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="Actions">
                            <FontIcon Glyph="&#xE712;" FontSize="13" />
                            <Button.Flyout>
                                <MenuFlyout Placement="Bottom">
                                    <MenuFlyoutItem Text="Select all"      Command="{x:Bind ViewModel.SelectAllCommand}" />
                                    <MenuFlyoutItem Text="Select none"     Command="{x:Bind ViewModel.SelectNoneCommand}" />
                                    <MenuFlyoutItem Text="Select defaults" Command="{x:Bind ViewModel.SelectDefaultsCommand}" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Expand all"   Command="{x:Bind ViewModel.ExpandAllCommand}" />
                                    <MenuFlyoutItem Text="Collapse all" Command="{x:Bind ViewModel.CollapseAllCommand}" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Sort by size ↓" Command="{x:Bind ViewModel.SortResultsDescCommand}" />
                                    <MenuFlyoutItem Text="Sort by size ↑" Command="{x:Bind ViewModel.SortResultsAscCommand}" />
                                    <MenuFlyoutSeparator />
                                    <!-- Reloads Winapp2.ini from disk; also triggered by F5 -->
                                    <MenuFlyoutItem Text="Refresh" Command="{x:Bind ViewModel.RefreshCommand}">
                                        <MenuFlyoutItem.KeyboardAccelerators>
                                            <KeyboardAccelerator Key="F5" />
                                        </MenuFlyoutItem.KeyboardAccelerators>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <!-- Detail header;this replaces results header when a result row is open.
                         Shows back button + entry name + open-folder + delete buttons. -->
                    <Grid Visibility="{x:Bind ViewModel.IsShowingDetail, Mode=OneWay,
                              Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />    <!-- entry name; truncates if too long -->
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Back;so it returns to results list (clears SelectedResultLine) -->
                        <Button Grid.Column="0"
                                Command="{x:Bind ViewModel.ClearDetailCommand}"
                                Width="24" Height="24" Padding="0"
                                ToolTipService.ToolTip="Back to results">
                            <FontIcon Glyph="&#xE72B;" FontSize="14" />
                        </Button>

                        <!-- SelectedAppName = the AppName of whichever result row was clicked -->
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.SelectedAppName, Mode=OneWay}"
                                   Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center"
                                   Margin="8,0"
                                   TextTrimming="CharacterEllipsis" />

                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                            <!-- Opens the folder of the first file in Explorer -->
                            <Button Command="{x:Bind ViewModel.OpenFolderCommand}"
                                    Width="28" Height="28" Padding="0"
                                    ToolTipService.ToolTip="Open folder in Explorer">
                                <FontIcon Glyph="&#xE838;" FontSize="13" />
                            </Button>
                            <!-- Cleans only this single entry without touching the rest -->
                            <Button Command="{x:Bind ViewModel.CleanSelectedCommand}"
                                    Width="28" Height="28" Padding="0"
                                    ToolTipService.ToolTip="Delete these files now">
                                <FontIcon Glyph="&#xE74D;" FontSize="13" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- Indeterminate scan bar; spans full width, sits on top of row 1 while busy -->
        <ProgressBar Grid.Row="1"
                     VerticalAlignment="Top"
                     IsIndeterminate="True"
                     Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                         Converter={StaticResource BoolToVisibilityConverter}}" />

        <!-- MAIN AREA - left 280px = entry tree, 1px divider, right * = results/detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="420" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL - entry tree -->
            <Grid Grid.Column="0">

                <!-- Empty state: nothing loaded yet (IsEmpty = Categories.Count == 0) -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay,
                                Converter={StaticResource BoolToVisibilityConverter}}">
                    <FontIcon Glyph="&#xE8A5;" FontSize="36"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="Winapp2.ini loads automatically at startup."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               TextAlignment="Center" />
                </StackPanel>

                <!-- Entry tree: one Expander per category, one row per app inside.
                     Hidden until something is loaded (IsNotEmpty). -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Margin="0,8,0,0"
                              Padding="0,0,0,24"
                              Visibility="{x:Bind ViewModel.IsNotEmpty, Mode=OneWay,
                                  Converter={StaticResource BoolToVisibilityConverter}}">
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                                  Padding="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CleanerCategoryViewModel">

                                <!-- One collapsible group per category (e.g. "Google Chrome") -->
                                <Expander HorizontalAlignment="Stretch"
                                          HorizontalContentAlignment="Stretch"
                                          IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                          Margin="4,3,4,0"
                                          Padding="0">

                                    <!-- Category header: name + hover [...] menu -->
                                    <Expander.Header>
                                        <Grid HorizontalAlignment="Stretch"
                                              PointerEntered="CatHeader_PointerEntered"
                                              PointerExited="CatHeader_PointerExited">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{x:Bind Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTipService.ToolTip="{x:Bind Name}"
                                                       VerticalAlignment="Center" />

                                            <!-- [...] category actions; fades in on hover via code-behind -->
                                            <Button Grid.Column="1"
                                                    Width="26" Height="26" Padding="0"
                                                    Margin="8,0,0,0"
                                                    Opacity="0"
                                                    ToolTipService.ToolTip="Category actions">
                                                <Button.Resources>
                                                    <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                                                </Button.Resources>
                                                <FontIcon Glyph="&#xE712;" FontSize="13" />
                                                <Button.Flyout>
                                                    <MenuFlyout Placement="Bottom">
                                                        <MenuFlyoutItem Text="Select all"
                                                                        Command="{x:Bind SelectAllCommand}" />
                                                        <MenuFlyoutItem Text="Select none"
                                                                        Command="{x:Bind SelectNoneCommand}" />
                                                        <MenuFlyoutItem Text="Select defaults"
                                                                        Command="{x:Bind SelectDefaultsCommand}" />
                                                        <MenuFlyoutSeparator />
                                                        <!-- Tag passes the CategoryViewModel to the click handler -->
                                                        <MenuFlyoutItem Text="Analyze category"
                                                                        Tag="{x:Bind}"
                                                                        Click="CatAnalyze_Click" />
                                                        <MenuFlyoutItem Text="Clean category"
                                                                        Tag="{x:Bind}"
                                                                        Click="CatClean_Click" />
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </Expander.Header>

                                    <!-- Entry rows inside the category -->
                                    <ItemsControl ItemsSource="{x:Bind Entries, Mode=OneWay}"
                                                  Padding="4,0,0,4">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:CleanerEntryViewModel">
                                                <!-- Three columns: [checkbox+name] [size after scan] [...] -->
                                                <Grid Padding="2,1" Margin="16,0,0,0"
                                                      PointerEntered="EntryRow_PointerEntered"
                                                      PointerExited="EntryRow_PointerExited">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" /> <!-- size label -->
                                                        <ColumnDefinition Width="Auto" /> <!-- [...] button -->
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Checkbox — Warning tooltip from Winapp2.ini Warning= field.
                                                         Orange icon appears when HasWarning is true. -->
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                              ToolTipService.ToolTip="{x:Bind Warning}"
                                                              MinWidth="0"
                                                              Padding="6,3">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon Glyph="&#xE7BA;"
                                                                      FontSize="11"
                                                                      Foreground="OrangeRed"
                                                                      VerticalAlignment="Center"
                                                                      Visibility="{x:Bind HasWarning, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                            <TextBlock Text="{x:Bind Name}"
                                                                       FontSize="12"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTipService.ToolTip="{x:Bind Name}" />
                                                        </StackPanel>
                                                    </CheckBox>

                                                    <!-- SizeText: empty string until this entry has been scanned.
                                                         Updated live by UpdateEntrySize() in the ViewModel. -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{x:Bind SizeText, Mode=OneWay}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Margin="2,0,4,0" />

                                                    <!-- [...] entry actions;fades in on hover.
                                                         Tag="{x:Bind}" passes this EntryViewModel to the click handlers. -->
                                                    <Button Grid.Column="2"
                                                            Width="22" Height="22" Padding="0"
                                                            Margin="0,0,4,0"
                                                            Opacity="0"
                                                            ToolTipService.ToolTip="Entry actions">
                                                        <FontIcon Glyph="&#xE712;" FontSize="10" />
                                                        <Button.Flyout>
                                                            <MenuFlyout Placement="Bottom">
                                                                <MenuFlyoutItem Text="Analyze"
                                                                                Tag="{x:Bind}"
                                                                                Click="EntryAnalyze_Click" />
                                                                <MenuFlyoutItem Text="Clean"
                                                                                Tag="{x:Bind}"
                                                                                Click="EntryClean_Click" />
                                                            </MenuFlyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Vertical divider between left and right panels -->
            <Border Grid.Column="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- RIGHT PANEL - results list + detail view + buttons -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />    <!-- results or detail list -->
                    <RowDefinition Height="Auto" /> <!-- status text -->
                    <RowDefinition Height="Auto" /> <!-- Analyze/Run Cleaner buttons -->
                </Grid.RowDefinitions>

                <!-- Results list — each row is one scanned app.
                     Click a row >> SelectedResultLine is set >> switches to detail view.
                     AppName = entry name (bold); tooltip on it shows the category.
                     CountSummary = "3988 files · 2 registry" (gray, line 2).
                     Size = formatted bytes from the scan (accent, right). -->
                <ListView Grid.Row="0"
                          x:Name="ResultsListView"
                          ItemsSource="{x:Bind ViewModel.ResultLines, Mode=OneWay}"
                          SelectionMode="None"
                          IsItemClickEnabled="True"
                          ItemClick="ResultsListView_ItemClick"
                          Padding="0,2"
                          Visibility="{x:Bind ViewModel.IsShowingList, Mode=OneWay,
                              Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ScanResultLine">
                            <Grid Padding="12,7"
                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" /> <!-- size + chevron -->
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" /> <!-- AppName -->
                                    <RowDefinition Height="Auto" /> <!-- SubLine -->
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{x:Bind AppName}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- "3988 files · 2 registry" -->
                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           Text="{x:Bind CountSummary}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Margin="0,1,0,0" />

                                <!-- Size in accent color + chevron to signal the row is clickable -->
                                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                            Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center" Margin="12,0,0,0">
                                    <TextBlock Text="{x:Bind Size}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                    <FontIcon Glyph="&#xE76C;" FontSize="10"
                                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                              VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Detail list; flat "header + paths" list for the selected entry.
                     DetailLine.IsHeader = true : accent bold section title ("Files (10)")
                     DetailLine.IsHeader = false : dimmed path row -->
                <ListView Grid.Row="0"
                          ItemsSource="{x:Bind ViewModel.DetailLines, Mode=OneWay}"
                          SelectionMode="None"
                          Padding="0,2"
                          Visibility="{x:Bind ViewModel.IsShowingDetail, Mode=OneWay,
                              Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DetailLine">
                            <Grid Padding="12,3">
                                <!-- Section header: "Files (3988)" or "Registry (2)" -->
                                <TextBlock Text="{x:Bind Text}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                           Margin="0,6,0,2"
                                           Visibility="{x:Bind IsHeader,
                                               Converter={StaticResource BoolToVisibilityConverter}}" />
                                <!-- Path row: full file path or registry key -->
                                <TextBlock Text="{x:Bind Text}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{x:Bind IsNotHeader,
                                               Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Status text: last status message from the ViewModel (scan progress, errors, done) -->
                <TextBlock Grid.Row="1"
                           Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"
                           Padding="12,4,12,0" />

                <!-- Action buttons: Analyze (accent, left) + Run Cleaner (right) -->
                <Grid Grid.Row="2"
                      BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                      BorderThickness="0,1,0,0"
                      Padding="12,8,12,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Analyze: runs CleaningService.AnalyzeAsync for all checked entries -->
                    <Button Grid.Column="0"
                            Content="Analyze"
                            Command="{x:Bind ViewModel.AnalyzeCommand}"
                            Style="{StaticResource AccentButtonStyle}"
                            MinWidth="110"
                            Height="32" />

                    <!-- Run Cleaner: uses Click+code-behind because of the warning dialog flow.
                         IsEnabled bound separately since Click bypasses Command.CanExecute. -->
                    <Button Grid.Column="2"
                            Content="Run Cleaner"
                            Click="RunCleaner_Click"
                            IsEnabled="{x:Bind ViewModel.CanRunCleaner, Mode=OneWay}"
                            MinWidth="120"
                            Height="32" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
